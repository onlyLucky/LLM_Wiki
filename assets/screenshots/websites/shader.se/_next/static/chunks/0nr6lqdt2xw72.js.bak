at our website.\n\n## 3. We're based in Sweden.\n\nThe land of modesty. Of lagom. Of not making a fuss. Swedes don't win awards. We win through quiet competence, firm handshakes, and converting prospects into long-term partners over a sensible lunch.\n\n## 4. Awards don't pay the bills.\n\nYou know what pays the bills? Bills. Specifically, the ones we send to our clients. On time. Every time. That's the real trophy.\n\n\nSo rest assured: Shader will remain award-free. Always has been. Always will be. This is a promise from our leadership team, and we intend to keep it. We would stake our reputation on it. We would stake our golden tie on it. \n";var LC=e.i(44664);let LI={title:(0,LC.getTitle)(Lv),markdown:Lv},LS=(0,LC.getContentBlocks)(Lv).filter(e=>"heading"!==e.type||1!==e.depth);function Lb(e){let t,r,i,n,a,s,o=(0,eh.c)(6);o[0]===Symbol.for("react.memo_cache_sentinel")?(t={fontSize:22,lineHeight:"26px",fontWeight:"bold",marginBottom:-4,lg:{fontSize:24,lineHeight:"32px",marginBottom:-6},xl:{fontSize:28,lineHeight:"36px",marginBottom:-8}},o[0]=t):t=o[0];let l=t;return o[1]===Symbol.for("react.memo_cache_sentinel")?(r={paddingX:16,paddingY:12},i={paddingX:40,paddingY:16},n={paddingX:40,paddingY:24},o[1]=r,o[2]=i,o[3]=n):(r=o[1],i=o[2],n=o[3]),o[4]===Symbol.for("react.memo_cache_sentinel")?(a=(0,ec.jsx)(wQ,{width:"100%",paddingX:16,paddingTop:8,paddingBottom:8,sm:r,md:i,xl:n,alignItems:"center",justifyContent:"center",maxWidth:1600,marginX:"auto",maxHeight:2e3,children:(0,ec.jsx)(wG,{textAlign:"center",width:"100%",fontSize:42,lineHeight:"42px",sm:{fontSize:48,lineHeight:"48px",maxWidth:640},md:{fontSize:64,lineHeight:"64px"},lg:{fontSize:96,lineHeight:"96px",maxWidth:1080},xl:{fontSize:110,lineHeight:"110px",maxWidth:1080},children:LI.title})}),o[4]=a):a=o[4],o[5]===Symbol.for("react.memo_cache_sentinel")?(s=(0,ec.jsxs)(ec.Fragment,{children:[a,(0,ec.jsx)(wQ,{width:"100%",display:"flex",maxWidth:1080,marginX:"auto",children:(0,ec.jsx)(wQ,{flexDirection:"column",gap: